generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String?        // nullable for Google Auth users who don't set a password
  name             String
  googleId         String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  RefreshTokens    RefreshToken[]
  CreatedGroups    Group[]        @relation("CreatedGroups")
  GroupMemberships GroupMember[]  @relation("GroupMemberships")
  PaidExpenses     Expense[]      @relation("PaidExpenses")
  ExpenseParticipations ExpenseParticipant[] @relation("ExpenseParticipations")
  PaidSettlements     Settlement[] @relation("PaidSettlements")
  ReceivedSettlements Settlement[] @relation("ReceivedSettlements")
  AuditLogs        AuditLog[]
  Notifications    Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  currency    String        @default("USD")
  creatorId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  creator     User          @relation("CreatedGroups", fields: [creatorId], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  role      String    @default("MEMBER") // "ADMIN" or "MEMBER"
  joinedAt  DateTime  @default(now())
  leftAt    DateTime? // NULL means currently active
  
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Expense {
  id                          String               @id @default(uuid())
  groupId                     String
  description                 String
  amount                      Decimal              @db.Decimal(15, 4)
  currency                    String               @default("INR")
  originalCurrency            String?              // The currency as it appeared in the CSV/form
  originalAmount              Decimal?             @db.Decimal(15, 4) // Pre-conversion amount
  exchangeRateToGroupCurrency Decimal              @default(1.0) @db.Decimal(15, 6)
  exchangeRateSource          String?              // e.g. "frankfurter" or "manual"
  exchangeRateDate            DateTime?            // The date the exchange rate was fetched for
  expenseDate                 DateTime             @default(now())
  paidById                    String
  splitType                   String               // "EQUAL", "UNEQUAL", "PERCENTAGE", "SHARE"
  importBatchId               String?              // The ImportBatch this came from, if any
  notes                       String?
  category                    String?
  deletedAt                   DateTime?            // Soft delete
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  
  group                       Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy                      User                 @relation("PaidExpenses", fields: [paidById], references: [id])
  participants                ExpenseParticipant[]
}

model ExpenseParticipant {
  id              String   @id @default(uuid())
  expenseId       String
  userId          String
  amountOwed      Decimal  @db.Decimal(15, 4)
  splitValue      Decimal? @db.Decimal(15, 4) // Raw input value (20 for 20%, 3 for 3 shares, exact amount)
  shareNumerator  Int?     // For fractional share splits
  shareDenominator Int?    // For fractional share splits
  percentage      Decimal? @db.Decimal(7, 4)  // Explicit percentage
  isSettled       Boolean  @default(false)     // Whether this participant's share has been settled
  
  expense         Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user            User     @relation("ExpenseParticipations", fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Settlement {
  id            String   @id @default(uuid())
  groupId       String
  payerId       String
  receiverId    String
  amount        Decimal  @db.Decimal(15, 4)
  currency      String   @default("INR")
  date          DateTime @default(now())
  importBatchId String?  // The ImportBatch this came from, if any
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer         User     @relation("PaidSettlements", fields: [payerId], references: [id])
  receiver      User     @relation("ReceivedSettlements", fields: [receiverId], references: [id])
}

model ImportBatch {
  id          String      @id @default(uuid())
  groupId     String
  status      String      @default("PENDING") // PENDING, NEEDS_REVIEW, READY, COMMITTED, REJECTED
  totalRows   Int         @default(0)
  anomalyCount Int        @default(0)
  committedBy String?     // userId who committed
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  
  rows        ImportRow[]
}

model ImportRow {
  id          String      @id @default(uuid())
  batchId     String
  rawRowData  Json
  parsedData  Json?
  anomalies   Json?
  status      String      @default("PENDING") // PENDING, RESOLVED, SKIPPED
  actionTaken String?
  
  batch       ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

// --- NEW TABLES FROM COMPLIANCE REPORT ---

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // e.g. "EXPENSE_CREATED", "ANOMALY_RESOLVED", "BATCH_COMMITTED"
  entityType String   // e.g. "Expense", "ImportBatch"
  entityId   String   // The ID of the entity acted upon
  metadata   Json?    // Any extra context (old value, new value, etc.)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
}

model ExchangeRateCache {
  id         String   @id @default(uuid())
  date       String   // ISO date string: "2026-01-15"
  fromCurrency String
  toCurrency String
  rate       Decimal  @db.Decimal(15, 6)
  source     String   @default("frankfurter")
  fetchedAt  DateTime @default(now())

  @@unique([date, fromCurrency, toCurrency])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // e.g. "GROUP_INVITE", "SETTLEMENT_REQUESTED", "EXPENSE_ADDED"
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
